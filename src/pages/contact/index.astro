---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Card from "../../components/Card.astro";
---

<BaseLayout
  title="Contact"
  description="Get in touch with Absurd Industries. Reach us on Discord, email, or social media."
  activeTab=""
>
  <div class="max-w-4xl mx-auto px-5 sm:px-6 pt-6 pb-6">
    <div class="mb-2">
      <h1 class="font-serif text-3xl sm:text-4xl font-bold tracking-tight text-ink mb-2">
        <i class="ph-duotone ph-envelope-simple text-ink mr-2" style="font-size:1.4rem;"></i>Contact
      </h1>
      <p class="text-sm text-ink max-w-lg leading-relaxed" style="font-weight:450;">
        Have a question, idea, or just want to say hello? Here's how to reach us.
      </p>
    </div>
  </div>

  <section class="pb-16 sm:pb-20">
    <div class="max-w-4xl mx-auto px-5 sm:px-6">

      <!-- Primary: Discord -->
      <Card>
        <div class="contact-block">
          <div class="contact-icon-wrap contact-icon--discord">
            <svg viewBox="0 0 24 24" fill="currentColor" class="contact-svg-icon"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/></svg>
          </div>
          <div class="contact-text">
            <h2 class="font-serif font-bold text-lg text-ink mb-0.5">Discord</h2>
            <p class="text-sm text-stencil leading-relaxed mb-3" style="font-weight:450;">
              The fastest way to reach us. Ask questions, share ideas, or just hang out with the community.
            </p>
            <a href="https://discord.gg/DUSUtguG2H" target="_blank" rel="noopener" class="contact-link">
              Join our Discord
              <i class="ph-bold ph-arrow-up-right" style="font-size:0.7rem;"></i>
            </a>
          </div>
        </div>
      </Card>

      <!-- Email -->
      <div class="mt-4">
        <Card>
          <div class="contact-block">
            <div class="contact-icon-wrap contact-icon--email">
              <i class="ph-duotone ph-envelope-simple"></i>
            </div>
            <div class="contact-text">
              <h2 class="font-serif font-bold text-lg text-ink mb-0.5">Email</h2>
              <p class="text-sm text-stencil leading-relaxed mb-3" style="font-weight:450;">
                For partnerships, press, or anything that needs a longer conversation.
              </p>
              <a href="mailto:hello@absurd.industries" class="contact-link">
                hello@absurd.industries
                <i class="ph-bold ph-arrow-up-right" style="font-size:0.7rem;"></i>
              </a>
            </div>
          </div>
        </Card>
      </div>

      <!-- Social links grid -->
      <div class="mt-4">
        <Card>
          <div class="contact-social-block">
            <h2 class="font-serif font-bold text-lg text-ink mb-3">Find us elsewhere</h2>
            <div class="contact-social-grid">
              <a href="https://www.instagram.com/absurd.science?igsh=ZXpld2hqbm82OTFk" target="_blank" rel="noopener" class="contact-social-item">
                <svg viewBox="0 0 24 24" fill="currentColor" class="contact-social-svg"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
                <span>Instagram</span>
              </a>
              <a href="https://www.youtube.com/@absurd.industries" target="_blank" rel="noopener" class="contact-social-item">
                <svg viewBox="0 0 24 24" fill="currentColor" class="contact-social-svg"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                <span>YouTube</span>
              </a>
              <a href="https://in.linkedin.com/company/absurd-explorations" target="_blank" rel="noopener" class="contact-social-item">
                <svg viewBox="0 0 24 24" fill="currentColor" class="contact-social-svg"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                <span>LinkedIn</span>
              </a>
              <a href="https://x.com/absurdit_y" target="_blank" rel="noopener" class="contact-social-item">
                <svg viewBox="0 0 24 24" fill="currentColor" class="contact-social-svg"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                <span>X</span>
              </a>
              <a href="https://github.com/absurd-industries" target="_blank" rel="noopener" class="contact-social-item">
                <svg viewBox="0 0 24 24" fill="currentColor" class="contact-social-svg"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
                <span>GitHub</span>
              </a>
            </div>
          </div>
        </Card>
      </div>

      <!-- Location note -->
      <div class="mt-6 text-center">
        <p class="text-sm text-stencil" style="font-weight:450;">
          <i class="ph-duotone ph-map-pin mr-1" style="font-size:0.85rem;"></i>
          Based in Bengaluru, India &middot; Building for the world
        </p>
      </div>

    </div>
  </section>

  <style>
    .contact-block {
      display: flex;
      align-items: flex-start;
      gap: 1.25rem;
      padding: 1.5rem;
    }
    @media (max-width: 480px) {
      .contact-block {
        flex-direction: column;
        gap: 1rem;
      }
    }

    .contact-icon-wrap {
      width: 48px;
      height: 48px;
      border-radius: 0.75rem;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      font-size: 1.3rem;
    }
    .contact-icon--discord {
      background: rgba(88, 101, 242, 0.1);
      color: #5865F2;
    }
    .contact-icon--email {
      background: rgba(255, 89, 0, 0.08);
      color: #D94800;
    }
    .contact-svg-icon {
      width: 1.3rem;
      height: 1.3rem;
    }

    .contact-text {
      flex: 1;
      min-width: 0;
    }

    .contact-link {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      font-size: 0.85rem;
      font-weight: 700;
      color: #D94800;
      text-decoration: none;
      transition: color 0.15s;
    }
    .contact-link:hover {
      color: #FF5900;
    }

    .contact-social-block {
      padding: 1.5rem;
    }
    .contact-social-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 0.75rem;
    }
    @media (min-width: 480px) {
      .contact-social-grid {
        grid-template-columns: repeat(3, 1fr);
      }
    }
    @media (min-width: 768px) {
      .contact-social-grid {
        grid-template-columns: repeat(5, 1fr);
      }
    }

    .contact-social-item {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
      padding: 1.25rem 0.75rem;
      border-radius: 0.75rem;
      border: 1px solid rgba(26, 26, 26, 0.06);
      background: rgba(250, 243, 232, 0.5);
      text-decoration: none;
      color: #1A1A1A;
      font-size: 0.8rem;
      font-weight: 600;
      transition: all 0.15s;
    }
    .contact-social-item:hover {
      border-color: rgba(26, 26, 26, 0.15);
      background: rgba(250, 243, 232, 0.85);
      color: #D94800;
    }
    .contact-social-svg {
      width: 1.5rem;
      height: 1.5rem;
      color: #4A3D2F;
      transition: color 0.15s;
    }
    .contact-social-item:hover .contact-social-svg {
      color: #D94800;
    }
  </style>
</BaseLayout>
