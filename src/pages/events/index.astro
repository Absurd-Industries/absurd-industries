---
/**
 * Events listing page.
 * Shows Bengaluru-first STEAM events — meetups, workshops, hackathons,
 * talks, and conferences. Calendar/planner view with city filtering
 * and search, handled client-side by the EventsListing Vue island.
 */

import BaseLayout from "../../layouts/BaseLayout.astro";
import EventsListing from "../../components/EventsListing.vue";
import { events } from "../../data/events";
---

<BaseLayout
  title="Events"
  description="Bengaluru-first STEAM events — meetups, workshops, hackathons, talks, and conferences for makers, scientists, artists, and engineers."
  activeTab="events"
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 pt-8 pb-8 md:pt-12 md:pb-12">
    <!-- Page Header -->
    <div class="mb-6">
      <h1
        class="font-serif text-3xl sm:text-4xl font-black tracking-tight mb-2"
        style="color: #1A1A1A;"
      >
        Events
      </h1>
      <p class="text-sm max-w-lg leading-relaxed" style="color: #1A1A1A; opacity: 0.8;">
        Bengaluru-first STEAM events for makers, scientists, artists, engineers,
        and the endlessly curious. Find your people.
      </p>
    </div>

    <!-- Interactive calendar listing island -->
    <EventsListing events={events} client:load />
  </div>
</BaseLayout>
