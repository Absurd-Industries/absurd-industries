---
/**
 * Steam-style maker profile detail page.
 * Generated at build time from the makers data via getStaticPaths().
 *
 * Layout: profile banner, two-column body (main + sidebar), with
 * showcase, activity feed, projects grid, workshop section,
 * comment wall, badges, skills, and about panels.
 */

import BaseLayout from "../../layouts/BaseLayout.astro";
import Card from "../../components/Card.astro";
import Tag from "../../components/Tag.astro";
import ProgressBar from "../../components/ProgressBar.astro";
import { makers } from "../../data/makers";
import type { Maker } from "../../types";

export function getStaticPaths() {
  return makers.map((maker) => ({
    params: { slug: maker.slug },
    props: { maker },
  }));
}

const { maker } = Astro.props as { maker: Maker };

// ────────────────────────────────────────────────────────────
// Per-maker enriched data (mock / derived for static build)
// In production these would come from the API.
// ────────────────────────────────────────────────────────────

/** Banner colour — use avatarColor as the default */
const bannerColor = maker.avatarColor;
const bannerAccent = "#FF5900";

const initial = maker.name.charAt(0).toUpperCase();
const firstName = maker.name.split(" ")[0];

/** Mock level based on projects + backers */
const level = Math.min(Math.floor((maker.projects * 2 + maker.backers / 20)), 30);

/** Showcase — first project (mock campaign data) */
const showcase = {
  name: `${firstName}'s Featured Project`,
  description: maker.bio ?? `Open-source ${maker.specialty.toLowerCase()} project by ${maker.name}.`,
  icon: getSpecialtyIcon(maker.specialty),
  category: maker.specialty,
  license: "CERN-OHL-S",
  percent: Math.min(Math.round((maker.backers / (maker.backers + 50)) * 100), 100),
  goal: `₹${Math.round((maker.backers * 1400) / 100000).toFixed(0)},00,000`,
  backers: maker.backers,
  link: "/campaigns",
};

function getSpecialtyIcon(specialty: string): string {
  const map: Record<string, string> = {
    Electronics: "cpu",
    Firmware: "code",
    "Product Design": "cube",
    Education: "graduation-cap",
    Robotics: "robot",
    Audio: "speaker-high",
  };
  return map[specialty] ?? "wrench";
}

/** Activity feed entries */
const activities = [
  {
    icon: "rocket-launch",
    text: `Launched <strong>${showcase.name}</strong> campaign`,
    time: "3 days ago",
    highlight: true,
    miniCard: {
      icon: showcase.icon,
      name: showcase.name,
      percent: showcase.percent,
      backers: showcase.backers,
    },
  },
  {
    icon: "article",
    text: `Published build journal: <strong>Field Testing v${maker.projects}</strong>`,
    time: "1 week ago",
    highlight: false,
    miniCard: null as null | { icon: string; name: string; percent: number; backers: number },
  },
  {
    icon: "file-text",
    text: `Contributed specs to a <span class="text-stamp font-semibold">Community Request</span>`,
    time: "2 weeks ago",
    highlight: false,
    miniCard: null as null | { icon: string; name: string; percent: number; backers: number },
  },
  {
    icon: "heart",
    text: "Backed <strong>Desktop CNC Mill</strong> by Vikram Rao",
    time: "3 weeks ago",
    highlight: false,
    miniCard: null as null | { icon: string; name: string; percent: number; backers: number },
  },
  {
    icon: "trophy",
    text: `Earned badge: <strong>${maker.backers >= 100 ? "Crowd Favourite" : "First Backer"}</strong>`,
    time: "1 month ago",
    highlight: true,
    miniCard: null as null | { icon: string; name: string; percent: number; backers: number },
  },
  {
    icon: "user-plus",
    text: "Joined <strong>Absurd Industries</strong>",
    time: "2024",
    highlight: false,
    miniCard: null as null | { icon: string; name: string; percent: number; backers: number },
  },
];

/** Projects list */
const projects = [
  {
    name: showcase.name,
    description: showcase.description,
    icon: showcase.icon,
    status: "Live" as const,
    percent: showcase.percent,
    backers: showcase.backers,
  },
  ...(maker.projects > 1
    ? [
        {
          name: `${maker.skills[0]} Monitor`,
          description: `Open-source ${maker.skills[0].toLowerCase()} monitoring system with wireless alerts.`,
          icon: "chart-line",
          status: "Completed" as const,
          percent: 100,
          backers: Math.round(maker.backers * 0.4),
        },
      ]
    : []),
  ...(maker.projects > 2
    ? [
        {
          name: `${maker.skills[1] ?? maker.specialty} Kit`,
          description: `Upcoming kit for ${maker.specialty.toLowerCase()} enthusiasts.`,
          icon: "package",
          status: "Coming Soon" as const,
          percent: null as number | null,
          backers: 0,
        },
      ]
    : []),
];

/** Badges */
const badges = [
  {
    name: "Guild Member",
    icon: "seal-check",
    description: "Verified Absurd Industries maker",
    bg: "rgba(42,95,65,0.12)",
    color: "#2A5F41",
  },
  {
    name: "First Campaign",
    icon: "flag-banner",
    description: "Successfully funded their first campaign",
    bg: "rgba(255,89,0,0.1)",
    color: "#FF5900",
  },
  ...(maker.backers >= 100
    ? [
        {
          name: "Crowd Favourite",
          icon: "users-three",
          description: "Projects loved by the community",
          bg: "rgba(26,26,26,0.08)",
          color: "#1A1A1A",
        },
      ]
    : []),
  {
    name: "Community Helper",
    icon: "handshake",
    description: "Contributed to community requests",
    bg: "rgba(42,95,65,0.12)",
    color: "#2A5F41",
  },
  {
    name: `${maker.specialty} Specialist`,
    icon: "lightning",
    description: `Specialist in ${maker.specialty}`,
    bg: "rgba(107,91,74,0.12)",
    color: "#6B5B4A",
  },
  {
    name: "Open Source",
    icon: "lock-key-open",
    description: "All projects use open-source licenses",
    bg: "rgba(255,89,0,0.1)",
    color: "#FF5900",
  },
];

/** Workshop / Setup */
const workshop = {
  name: `${firstName}'s Workshop`,
  location: maker.location,
  size: "Home workshop",
  hours: "Open for visits by appointment",
  equipment: [
    { name: "3D Printer", icon: "cube" },
    { name: "Soldering Station", icon: "fire" },
    { name: "Oscilloscope", icon: "wave-sine" },
    { name: "Multimeter", icon: "lightning" },
    { name: "Power Supply", icon: "battery-charging" },
    { name: "Hot Air Station", icon: "wind" },
  ],
};

/** Comments wall */
const comments = [
  {
    id: 1,
    author: "Vikram Rao",
    time: "2 days ago",
    text: `${firstName}'s documentation is incredible. This is what open source should look like.`,
  },
  {
    id: 2,
    author: "Arjun Nair",
    time: "1 week ago",
    text: `Thanks for the detailed specs! Your ${maker.skills[0]} recommendations were exactly what we needed.`,
  },
  {
    id: 3,
    author: "Community Member",
    time: "3 weeks ago",
    text: `Exceptional work on the ${maker.specialty.toLowerCase()} projects. Keep shipping!`,
  },
];

/** External links with icons */
const externalLinks = [
  ...(maker.links?.github
    ? [{ label: maker.links.github.replace("https://", ""), url: maker.links.github, iconClass: "fa-brands fa-github" }]
    : []),
  ...(maker.links?.website
    ? [{ label: maker.links.website.replace("https://", ""), url: maker.links.website, iconClass: "ph-bold ph-globe" }]
    : []),
  ...(maker.links?.twitter
    ? [{ label: maker.links.twitter.replace("https://twitter.com/", "@"), url: maker.links.twitter, iconClass: "fa-brands fa-x-twitter" }]
    : []),
];

/** Primary tools (derived from skills for display) */
const tools = maker.skills.slice(0, 4);

/** Contribution count (mock) */
const contributions = Math.round(maker.projects * 8 + maker.backers / 10);

---

<BaseLayout
  title={`${maker.name} — ${maker.title}`}
  description={maker.bio ?? `${maker.name} is a ${maker.title} from ${maker.location} on Absurd Industries.`}
  activeTab="makers"
  hideNav
>
  <section class="pt-6 pb-0 sm:pt-8">
    <div class="max-w-5xl mx-auto px-5 sm:px-6">
      <a href="/makers" class="back-btn">
        <i class="ph-bold ph-arrow-left"></i>
        Makers
      </a>
    </div>
  </section>


  <!-- ══════════════════════════════════════ -->
  <!-- PROFILE BANNER                        -->
  <!-- ══════════════════════════════════════ -->
  <section class="pt-4 pb-0" id="about">
    <div class="max-w-5xl mx-auto px-5 sm:px-6">
      <div
        class="profile-banner"
        style={`--banner-bg: ${bannerColor}; --banner-accent: ${bannerAccent};`}
        data-configurable="banner"
      >
        <!-- Punch hole (card stock ring) -->
        <div class="punch-hole"></div>

        <div class="relative z-10 px-6 py-8 sm:px-10 sm:py-10">
          <div class="banner-layout">

            <!-- Hexagon Avatar -->
            <div class="relative flex-shrink-0">
              <div class="hex-avatar">
                {maker.avatar ? (
                  <img src={maker.avatar} alt={maker.name} class="hex-avatar-img" />
                ) : (
                  <span class="font-serif font-bold text-4xl sm:text-5xl text-ink-faint/40 select-none">{initial}</span>
                )}
              </div>
              <div class="status-online"></div>
            </div>

            <!-- Name + rank -->
            <div class="banner-name-section">
              <div class="flex flex-wrap items-center gap-2 sm:gap-3">
                <h1 class="font-serif font-bold text-xl sm:text-2xl md:text-3xl text-paper tracking-tight leading-tight">{maker.name}</h1>
                <div class="level-badge" title={`Level ${level}`}>{level}</div>
                <span class="tag" style="background:rgba(42,95,65,0.25); color:#7FE0A0; font-size:0.6rem;">
                  <i class="ph-bold ph-seal-check mr-1" style="font-size:0.55rem;"></i>
                  Verified
                </span>
              </div>
              <p class="text-kraft text-sm mt-1 truncate">{maker.title}</p>
              <div class="flex flex-wrap items-center gap-3 mt-2 text-xs text-kraft-light">
                <span class="flex items-center gap-1">
                  <span class="w-2 h-2 rounded-full bg-funded inline-block"></span>
                  Online now
                </span>
                <span class="opacity-50 hidden sm:inline">|</span>
                <span class="hidden sm:inline">Last active 2 hours ago</span>
              </div>
              <div class="flex flex-wrap items-center gap-3 mt-2 text-xs text-kraft-light">
                <span class="flex items-center gap-1">
                  <i class="ph-bold ph-map-pin text-xs"></i>
                  {maker.location}
                </span>
                <span>·</span>
                <span>Member since 2024</span>
                <span>·</span>
                <span>{maker.specialty}</span>
              </div>
            </div>

            <!-- Action buttons -->
            <div class="banner-actions">
              <button
                class="btn btn-sm"
                style="border-color: rgba(250,243,232,0.3); color: #FAF3E8; background: transparent; border: 1.5px solid rgba(250,243,232,0.3);"
                onclick="window.__comingSoon && window.__comingSoon('Follow', 'Follow this maker to get notified when they launch new projects or post updates.')"
              >
                <i class="ph-bold ph-plus mr-1.5" style="font-size:0.75rem;"></i>
                Follow
              </button>
              <button
                class="btn btn-sm"
                style="background:rgba(250,243,232,0.12); color:#FAF3E8; border:1.5px solid rgba(250,243,232,0.2);"
                onclick="window.__comingSoon && window.__comingSoon('Direct Messages', 'Send a private message to this maker. Messaging launches with the next platform update.')"
              >
                <i class="ph-bold ph-envelope-simple mr-1.5" style="font-size:0.75rem;"></i>
                Message
              </button>
            </div>
          </div>

          <!-- Bio -->
          <div class="mt-4 pt-4 border-t border-paper/15">
            <p class="text-sm text-kraft leading-relaxed">{maker.bio ?? `${maker.name} is a ${maker.title} based in ${maker.location}.`}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════ -->
  <!-- TWO-COLUMN LAYOUT                     -->
  <!-- ══════════════════════════════════════ -->
  <section class="pt-6 sm:pt-8 pb-14 md:pb-20">
    <div class="max-w-5xl mx-auto px-5 sm:px-6">
      <div class="flex flex-col lg:flex-row gap-6">

        <!-- ══════════════════════════ -->
        <!-- MAIN COLUMN (LEFT)         -->
        <!-- ══════════════════════════ -->
        <div class="flex-1 min-w-0">

          <Card>
            <!-- ── WORKSHOP / SETUP ── -->
            <div id="setup" class="profile-section profile-section--dark">
                <div class="text-paper">
                  <div class="flex items-center gap-2 mb-5">
                    <i class="ph-bold ph-wrench text-stamp text-xl"></i>
                    <h2 class="font-serif font-bold text-xl sm:text-2xl tracking-tight">Workshop / Setup</h2>
                  </div>

                  <div class="flex flex-col sm:flex-row gap-6">
                    <!-- Workshop info -->
                    <div class="flex-1">
                      <h3 class="font-serif font-semibold text-base text-paper mb-2">{workshop.name}</h3>
                      <div class="space-y-2 mb-4">
                        <div class="flex items-center gap-2 text-sm text-kraft">
                          <i class="ph-bold ph-map-pin text-xs text-stamp"></i>
                          {workshop.location}
                        </div>
                        <div class="flex items-center gap-2 text-sm text-kraft">
                          <i class="ph-bold ph-ruler text-xs text-kraft-dark"></i>
                          {workshop.size}
                        </div>
                        <div class="flex items-center gap-2 text-sm text-kraft">
                          <i class="ph-bold ph-clock text-xs text-kraft-dark"></i>
                          {workshop.hours}
                        </div>
                      </div>

                      <button onclick="window.__comingSoon && window.__comingSoon('Lab Inventory', 'Browse the full equipment list and specs for this maker\'s workshop. Inventory pages are coming soon.')" class="flex items-center gap-2 text-sm font-semibold text-stamp hover:underline cursor-pointer bg-transparent border-none p-0">
                        <i class="ph-bold ph-package text-sm"></i>
                        View full lab inventory
                        <i class="ph-bold ph-arrow-right text-xs"></i>
                      </button>
                    </div>

                    <!-- Equipment grid -->
                    <div class="sm:w-56 flex-shrink-0">
                      <div class="text-xs font-semibold uppercase tracking-wider text-kraft-dark mb-3">Equipment</div>
                      <div class="grid grid-cols-2 gap-2">
                        {workshop.equipment.map((e) => (
                          <div class="flex items-center gap-2 p-2 rounded-lg" style="background:rgba(250,243,232,0.06);">
                            <div class="equip-icon" style="width:28px; height:28px; font-size:0.85rem;">
                              <i class={`ph-bold ph-${e.icon}`}></i>
                            </div>
                            <span class="text-[0.65rem] text-kraft leading-tight">{e.name}</span>
                          </div>
                        ))}
                      </div>
                    </div>
                  </div>

                  <!-- Workspace photo placeholders -->
                  <div class="mt-5 pt-5 border-t border-paper/10">
                    <div class="text-xs font-semibold uppercase tracking-wider text-kraft-dark mb-3">Workspace Photos</div>
                    <div class="grid grid-cols-3 gap-2">
                      {[1, 2, 3].map(() => (
                        <div class="aspect-video rounded-lg flex items-center justify-center" style="background:rgba(250,243,232,0.08);">
                          <i class="ph-bold ph-image text-xl text-paper/20"></i>
                        </div>
                      ))}
                    </div>
                  </div>
                </div>
            </div>

            <!-- ── ALL PROJECTS ── -->
            <div id="projects" class="profile-section">
              <h2 class="font-serif font-bold text-xl sm:text-2xl tracking-tight mb-5">Projects</h2>

              <div class="space-y-3">
                {projects.map((project, idx) => (
                  <a
                    href="/campaigns"
                    class:list={[
                      "block p-4 rounded-lg hover:bg-kraft-light/40 transition-colors no-underline text-ink group",
                      idx === 0 && "bg-kraft-light/30 border border-stamp/15",
                    ]}
                  >
                    <div class="flex items-center gap-3 mb-2">
                      <div class="w-10 h-10 rounded-lg bg-kraft-light flex items-center justify-center flex-shrink-0">
                        <i class={`ph-bold ph-${project.icon} text-lg text-stencil group-hover:text-stamp transition-colors`}></i>
                      </div>
                      <div class="flex-1 min-w-0">
                        <h3 class="text-sm font-semibold truncate group-hover:text-stamp transition-colors">{project.name}</h3>
                      </div>
                      <i class="ph-bold ph-caret-right text-xs text-ink-faint/40 flex-shrink-0"></i>
                    </div>
                    <p class="text-xs text-stencil leading-relaxed line-clamp-2">{project.description}</p>
                    {project.percent !== null && (
                      <div class="mt-2.5">
                        <ProgressBar percent={project.percent} hot={project.percent >= 100} />
                      </div>
                    )}
                  </a>
                ))}
              </div>
            </div>

            <!-- ── ACTIVITY & WALL ── -->
            <div id="wall" class="profile-section">
              <div class="flex items-center justify-between mb-5">
                <h2 class="font-serif font-bold text-xl sm:text-2xl tracking-tight">Activity & Wall</h2>
              </div>

              <!-- Recent Activity -->
              <h3 class="font-serif font-semibold text-base mb-4">Recent Activity</h3>
              <div class="space-y-4">
                {activities.map((a) => (
                  <div class="flex items-start gap-3">
                    <div class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5" style={`background: ${a.highlight ? "rgba(217,72,0,0.1)" : "rgba(26,26,26,0.04)"}`}>
                      <i class={`ph-bold ph-${a.icon} text-sm`} style={`color: ${a.highlight ? "#D94800" : "#4A3D2F"}`}></i>
                    </div>
                    <div class="flex-1">
                      <p class="text-sm text-ink leading-snug" set:html={a.text} />
                      <span class="text-xs text-ink-faint mt-0.5 block">{a.time}</span>

                      {a.miniCard && (
                        <div class="mt-2 p-3 rounded-lg bg-kraft-light/50 border border-ink/5">
                          <div class="flex items-center gap-2 mb-1.5">
                            <i class={`ph-bold ph-${a.miniCard.icon} text-sm text-stencil`}></i>
                            <span class="text-xs font-semibold text-ink">{a.miniCard.name}</span>
                          </div>
                          <div class="progress mb-1" style="height:4px;">
                            <div class="progress-fill" style={`width: ${a.miniCard.percent}%`}></div>
                          </div>
                          <div class="text-[0.6rem] text-ink-faint">
                            <strong class="text-ink font-semibold">{a.miniCard.percent}%</strong> funded
                          </div>
                        </div>
                      )}
                    </div>
                  </div>
                ))}
              </div>

              <!-- Divider -->
              <div class="border-t border-ink/5 pt-5 mt-6">
                <!-- Comments -->
                <h3 class="font-serif font-semibold text-base mb-4">Comments</h3>

                <!-- Existing comments -->
                <div class="mb-5">
                  {comments.map((c) => (
                    <div class="comment-entry">
                      <div class="flex items-start gap-3">
                        <div class="w-8 h-8 rounded-full bg-kraft-light flex items-center justify-center flex-shrink-0 mt-0.5">
                          <i class="ph-bold ph-user text-xs text-ink-faint"></i>
                        </div>
                        <div class="flex-1">
                          <div class="flex items-center gap-2 mb-1">
                            <span class="text-sm font-semibold text-ink">{c.author}</span>
                            <span class="text-[0.6rem] text-ink-faint">{c.time}</span>
                          </div>
                          <p class="text-sm text-ink-light leading-relaxed">{c.text}</p>
                        </div>
                      </div>
                    </div>
                  ))}
                </div>

                <!-- Comment form placeholder -->
                <div class="border-t border-ink/5 pt-4">
                  <div class="flex items-start gap-3">
                    <div class="w-8 h-8 rounded-full bg-kraft flex items-center justify-center flex-shrink-0 mt-0.5">
                      <i class="ph-bold ph-user text-xs text-ink-faint"></i>
                    </div>
                    <div class="flex-1">
                      <textarea
                        rows="2"
                        placeholder={`Leave a comment on ${firstName}'s wall...`}
                        class="w-full p-3 rounded-lg border border-ink/10 bg-paper text-sm focus:outline-none focus:border-stamp focus:ring-1 focus:ring-stamp/30 resize-none"
                        disabled
                      ></textarea>
                      <div class="flex justify-end mt-2">
                        <button class="btn btn-primary btn-sm" style="opacity:0.5; transform:none;" onclick="window.__comingSoon && window.__comingSoon('Profile Wall', 'Post comments on maker profiles. Wall comments launch with the next platform update.')">
                          <i class="ph-bold ph-paper-plane-tilt mr-1.5" style="font-size:0.7rem;"></i>
                          Post Comment
                        </button>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- ── BADGES ── -->
            <div id="badges" class="profile-section" data-configurable="badges">
              <h2 class="font-serif font-bold text-xl sm:text-2xl tracking-tight mb-4">Badges</h2>

              <div class="grid grid-cols-3 sm:grid-cols-6 gap-1">
                {badges.map((b) => (
                  <div class="badge-item" title={b.description}>
                    <div class="badge-icon" style={`background: ${b.bg}; color: ${b.color};`}>
                      <i class={`ph-bold ph-${b.icon}`}></i>
                    </div>
                    <span class="text-[0.58rem] text-ink-faint text-center font-semibold leading-tight">{b.name}</span>
                  </div>
                ))}
              </div>
            </div>
          </Card>

        </div>

        <!-- ══════════════════════════ -->
        <!-- SIDEBAR (RIGHT)            -->
        <!-- ══════════════════════════ -->
        <div class="w-full lg:w-80 flex-shrink-0 space-y-5">

          <!-- ── QUICK INFO + SKILLS ── -->
          <Card>
            <div class="p-5 sm:p-6">
              <h3 class="font-serif font-bold text-base mb-4">Profile Info</h3>

              <!-- Currently working on -->
              <div class="p-3 rounded-lg bg-kraft-light/50 border border-ink/5 mb-5">
                <div class="text-[0.6rem] font-semibold uppercase tracking-wider text-ink-faint mb-1.5">Currently working on</div>
                <p class="text-sm text-ink leading-snug font-medium">{showcase.name}</p>
              </div>

              <!-- Links -->
              {externalLinks.length > 0 && (
                <div class="border-t border-ink/5 pt-4 space-y-2.5">
                  {externalLinks.map((link) => (
                    <a href={link.url} target="_blank" rel="noopener" class="flex items-center gap-2.5 text-sm text-ink hover:text-stamp transition-colors no-underline group">
                      <i class={`${link.iconClass} text-base text-ink-faint group-hover:text-stamp transition-colors`}></i>
                      <span class="font-medium">{link.label}</span>
                      <i class="ph-bold ph-arrow-square-out text-xs text-ink-faint/50 ml-auto"></i>
                    </a>
                  ))}
                </div>
              )}
            </div>
            <div class="border-t border-ink/5 p-5 sm:p-6">
              <h3 class="font-serif font-bold text-base mb-4">Skills & Tools</h3>

              <div class="mb-4">
                <div class="text-xs font-semibold uppercase tracking-wider text-ink-faint mb-2">Skills</div>
                <div class="flex flex-wrap gap-1.5">
                  {maker.skills.map((s) => (
