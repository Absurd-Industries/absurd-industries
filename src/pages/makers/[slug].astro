<script is:inline data-astro-rerun>
(function() {
  var pills = document.querySelectorAll('.profile-nav-pill');
  var sections = ['about', 'setup', 'projects', 'wall', 'badges'];

  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        pills.forEach(function(p) { p.classList.remove('active'); });
        var pill = document.querySelector('.profile-nav-pill[href="#' + entry.target.id + '"]');
        if (pill) pill.classList.add('active');
      }
    });
  }, { threshold: 0.2, rootMargin: '-60px 0px -60% 0px' });

  sections.forEach(function(id) {
    var el = document.getElementById(id);
    if (el) observer.observe(el);
  });
})();
</script>

