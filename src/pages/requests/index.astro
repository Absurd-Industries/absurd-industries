---
/**
 * Requests listing page.
 * Displays a searchable, filterable, sortable feed of community requests.
 * Top section (header) sits on the kraft background, feed items sit on white paper.
 */

import BaseLayout from "../../layouts/BaseLayout.astro";
import RequestsListing from "../../components/RequestsListing.vue";
import { requests } from "../../data/requests";
import { makers } from "../../data/makers";

// Build a slug -> display name map for claimed-by lookups
const makerNames: Record<string, string> = {};
for (const m of makers) {
  makerNames[m.slug] = m.name;
}
---

<BaseLayout
  title="Requests"
  description="Request open-source projects that don't exist yet. Describe what you need, refine specs together, and let makers bring it to life."
  activeTab="requests"
>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 pt-6 pb-4">
    <!-- Page header (on kraft background) -->
    <div class="mb-6">
      <nav class="text-sm flex items-center gap-2 mb-4">
        <a href="/" class="text-ink-faint hover:text-stamp transition-colors" style="text-decoration:none;">Home</a>
        <span class="text-ink-faint/40">/</span>
        <span class="text-ink font-medium">Requests</span>
      </nav>
      <h1 class="font-serif text-3xl sm:text-4xl font-bold tracking-tight text-ink mb-2">
        Requests
      </h1>
      <p class="text-sm text-ink max-w-lg leading-relaxed">
        The world needs things that don't exist yet. Describe what you need,
        refine specs together, and let makers bring it to life.
      </p>
    </div>
  </div>

  <!-- White paper section for the feed -->
  <div class="requests-feed-bg">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 pt-8 pb-12">
      <RequestsListing
        requests={requests}
        makerNames={makerNames}
        client:load
      />
    </div>
  </div>

  <style>
    .requests-feed-bg {
      background-color: #FAF3E8;
      background-image: url('/images/paper-texture.png');
      background-repeat: repeat;
      background-size: 128px 128px;
      min-height: 60vh;
    }
  </style>
</BaseLayout>
