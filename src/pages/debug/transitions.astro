---
/**
 * Debug page -- demonstrates Astro View Transitions.
 * Shows each transition type with live examples and code snippets.
 * Includes interactive play/replay buttons for on-page animation demos.
 */

import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Transitions Debug" activeTab="">
  <section class="pt-8 pb-16">
    <div class="max-w-4xl mx-auto px-5 sm:px-6">
      <h1 class="font-serif font-bold text-3xl sm:text-4xl tracking-tight mb-2">
        <i class="ph-duotone ph-shuffle text-ink mr-2" style="font-size:1.4rem;"></i>View Transitions
      </h1>
      <p class="text-sm text-ink max-w-lg leading-relaxed mb-8">
        Astro's <code class="text-stamp font-mono text-xs bg-kraft-light px-1.5 py-0.5 rounded">ClientRouter</code> enables smooth page transitions.
        This page demonstrates the built-in transition types.
      </p>

      <div class="space-y-8">

        <!-- Fade -->
        <div class="card">
          <div class="card-bg"></div>
          <div class="card-content p-6">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-10 h-10 rounded-lg bg-kraft-light flex items-center justify-center">
                <i class="ph-bold ph-eye text-lg text-stencil"></i>
              </div>
              <div>
                <h2 class="font-serif font-bold text-lg">fade</h2>
                <span class="tag tag-default">Default</span>
              </div>
            </div>
            <p class="text-sm text-ink-light leading-relaxed mb-4">
              Cross-fades the old page out and the new page in. This is the default transition when no type is specified.
            </p>
            <div class="demo-wrap" data-transition="fade">
              <div class="demo-box demo-target">
                <span class="text-sm font-semibold text-paper">Fade Demo Element</span>
              </div>
              <button class="demo-play-btn">
                <i class="ph-bold ph-play mr-1" style="font-size:0.7rem;"></i>
                Play
              </button>
            </div>
            <pre class="code-block"><code>&lt;div transition:animate="fade"&gt;
  Content fades in/out
&lt;/div&gt;</code></pre>
          </div>
        </div>

        <!-- Slide -->
        <div class="card">
          <div class="card-bg"></div>
          <div class="card-content p-6">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-10 h-10 rounded-lg bg-kraft-light flex items-center justify-center">
                <i class="ph-bold ph-arrows-left-right text-lg text-stencil"></i>
              </div>
              <div>
                <h2 class="font-serif font-bold text-lg">slide</h2>
                <span class="tag tag-stamp">Directional</span>
              </div>
            </div>
            <p class="text-sm text-ink-light leading-relaxed mb-4">
              Old content slides out to the left while new content slides in from the right. On back navigation, the direction reverses.
            </p>
            <div class="demo-wrap" data-transition="slide">
              <div class="demo-box demo-target">
                <span class="text-sm font-semibold text-paper">Slide Demo Element</span>
              </div>
              <button class="demo-play-btn">
                <i class="ph-bold ph-play mr-1" style="font-size:0.7rem;"></i>
                Play
              </button>
            </div>
            <pre class="code-block"><code>&lt;div transition:animate="slide"&gt;
  Content slides left/right
&lt;/div&gt;</code></pre>
          </div>
        </div>

        <!-- Initial -->
        <div class="card">
          <div class="card-bg"></div>
          <div class="card-content p-6">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-10 h-10 rounded-lg bg-kraft-light flex items-center justify-center">
                <i class="ph-bold ph-play text-lg text-stencil"></i>
              </div>
              <div>
                <h2 class="font-serif font-bold text-lg">initial</h2>
                <span class="tag tag-default">One-shot</span>
              </div>
            </div>
            <p class="text-sm text-ink-light leading-relaxed mb-4">
              Only animates the first time the element appears (initial page load or first navigation to the page). Subsequent visits skip the animation.
            </p>
            <div class="demo-wrap" data-transition="initial">
              <div class="demo-box demo-target">
                <span class="text-sm font-semibold text-paper">Initial Demo Element</span>
              </div>
              <button class="demo-play-btn">
                <i class="ph-bold ph-play mr-1" style="font-size:0.7rem;"></i>
                Play
              </button>
            </div>
            <pre class="code-block"><code>&lt;div transition:animate="initial"&gt;
  Animates only on first appearance
&lt;/div&gt;</code></pre>
          </div>
        </div>

        <!-- None -->
        <div class="card">
          <div class="card-bg"></div>
          <div class="card-content p-6">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-10 h-10 rounded-lg bg-kraft-light flex items-center justify-center">
                <i class="ph-bold ph-prohibit text-lg text-stencil"></i>
              </div>
              <div>
                <h2 class="font-serif font-bold text-lg">none</h2>
                <span class="tag tag-default">Opt-out</span>
              </div>
            </div>
            <p class="text-sm text-ink-light leading-relaxed mb-4">
              Disables all transition animation for this element. Useful for persistent UI like headers, navbars, or sidebars that should not animate between pages.
            </p>
            <div class="demo-wrap" data-transition="none">
              <div class="demo-box demo-box--muted">
                <span class="text-sm font-semibold text-ink-faint">No Animation</span>
              </div>
              <button class="demo-play-btn demo-play-btn--disabled" disabled>
                <i class="ph-bold ph-prohibit mr-1" style="font-size:0.7rem;"></i>
                No Animation
              </button>
            </div>
            <pre class="code-block"><code>&lt;div transition:animate="none"&gt;
  No transition animation
&lt;/div&gt;

&lt;!-- Also useful on persistent elements --&gt;
&lt;nav transition:persist&gt;...&lt;/nav&gt;</code></pre>
          </div>
        </div>

        <!-- Morph (transition:name) -->
        <div class="card">
          <div class="card-bg"></div>
          <div class="card-content p-6">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-10 h-10 rounded-lg bg-kraft-light flex items-center justify-center">
                <i class="ph-bold ph-magic-wand text-lg text-stencil"></i>
              </div>
              <div>
                <h2 class="font-serif font-bold text-lg">morph (transition:name)</h2>
                <span class="tag tag-funded">Advanced</span>
              </div>
            </div>
            <p class="text-sm text-ink-light leading-relaxed mb-4">
              When two elements on different pages share the same <code class="text-stamp font-mono text-xs bg-kraft-light px-1.5 py-0.5 rounded">transition:name</code>,
              Astro morphs between them -- interpolating size, position, and appearance. This is how list-to-detail hero animations work.
            </p>
            <div class="grid grid-cols-2 gap-4 mb-4">
              <div class="demo-box demo-box--sm">
                <span class="text-xs font-semibold text-paper">Page A</span>
              </div>
              <div class="demo-box demo-box--lg">
                <span class="text-xs font-semibold text-paper">Page B</span>
              </div>
            </div>
            <pre class="code-block"><code set:text={`<!-- Page A: list card -->
<img transition:name={\`hero-\${slug}\`} />

<!-- Page B: detail hero -->
<img transition:name={\`hero-\${slug}\`} />

<!-- Astro morphs between them automatically -->`} /></pre>
          </div>
        </div>

        <!-- Persist -->
        <div class="card">
          <div class="card-bg"></div>
          <div class="card-content p-6">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-10 h-10 rounded-lg bg-kraft-light flex items-center justify-center">
                <i class="ph-bold ph-pin text-lg text-stencil"></i>
              </div>
              <div>
                <h2 class="font-serif font-bold text-lg">transition:persist</h2>
                <span class="tag tag-funded">Islands</span>
              </div>
            </div>
            <p class="text-sm text-ink-light leading-relaxed mb-4">
              Keeps a component's DOM and state alive across page navigations. Essential for media players, chat widgets, or any island that shouldn't remount.
            </p>
            <pre class="code-block"><code>&lt;!-- Audio player stays playing across pages --&gt;
&lt;AudioPlayer transition:persist client:load /&gt;

&lt;!-- Video keeps its playback position --&gt;
&lt;video transition:persist&gt;...&lt;/video&gt;</code></pre>
          </div>
        </div>

        <!-- Usage in this project -->
        <div class="card">
          <div class="card-bg"></div>
          <div class="card-content p-6">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-10 h-10 rounded-lg bg-kraft-light flex items-center justify-center">
                <i class="ph-bold ph-code text-lg text-stencil"></i>
              </div>
              <h2 class="font-serif font-bold text-lg">Setup in this project</h2>
            </div>
            <p class="text-sm text-ink-light leading-relaxed mb-4">
              View Transitions are enabled globally via <code class="text-stamp font-mono text-xs bg-kraft-light px-1.5 py-0.5 rounded">ClientRouter</code> in the base layout.
              Every page navigation uses the default <code class="text-stamp font-mono text-xs bg-kraft-light px-1.5 py-0.5 rounded">fade</code> transition automatically.
            </p>
            <pre class="code-block"><code set:text={`<!-- src/layouts/BaseLayout.astro -->
---
import { ClientRouter } from 'astro:transitions';
---
<head>
  <ClientRouter />
</head>

<!-- Per-element overrides -->
<h1 transition:animate="slide">Page Title</h1>
<img transition:name="campaign-hero" />

<!-- Re-run scripts after navigation -->
<script is:inline data-astro-rerun>
  // This runs on every page transition
</script>`} /></pre>
          </div>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .demo-box {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 80px;
    border-radius: 0.75rem;
    background: #1A1A1A;
    margin-bottom: 1rem;
  }
  .demo-box--muted {
    background: rgba(26, 26, 26, 0.06);
  }
  .demo-box--sm {
    height: 60px;
  }
  .demo-box--lg {
    height: 100px;
  }

  .code-block {
    background: #1A1A1A;
    color: #FAF3E8;
    padding: 1rem 1.25rem;
    border-radius: 0.625rem;
    font-size: 0.72rem;
    line-height: 1.6;
    overflow-x: auto;
    margin: 0;
  }
  .code-block code {
    font-family: 'DM Mono', 'SF Mono', monospace;
  }

  .demo-wrap {
    position: relative;
    margin-bottom: 1rem;
  }
  .demo-play-btn {
    display: inline-flex;
    align-items: center;
    padding: 0.4rem 0.9rem;
    border-radius: 0.5rem;
    font-size: 0.75rem;
    font-weight: 600;
    background: rgba(255, 89, 0, 0.1);
    color: #FF5900;
    border: 1.5px solid rgba(255, 89, 0, 0.2);
    cursor: pointer;
    transition: all 0.15s;
    font-family: 'DM Sans', system-ui, sans-serif;
  }
  .demo-play-btn:hover {
    background: #FF5900;
    color: #FAF3E8;
    border-color: #FF5900;
  }
  .demo-play-btn--disabled {
    background: rgba(26, 26, 26, 0.04);
    color: #6B5B4A;
    border-color: rgba(26, 26, 26, 0.08);
    cursor: not-allowed;
  }
  .demo-play-btn--disabled:hover {
    background: rgba(26, 26, 26, 0.04);
    color: #6B5B4A;
    border-color: rgba(26, 26, 26, 0.08);
  }

  @keyframes demo-fade-out-in {
    0% { opacity: 1; }
    40% { opacity: 0; }
    60% { opacity: 0; }
    100% { opacity: 1; }
  }
  @keyframes demo-slide-out-in {
    0% { transform: translateX(0); opacity: 1; }
    35% { transform: translateX(-100%); opacity: 0; }
    50% { transform: translateX(100%); opacity: 0; }
    100% { transform: translateX(0); opacity: 1; }
  }
  @keyframes demo-initial-in {
    0% { opacity: 0; transform: scale(0.9); }
    100% { opacity: 1; transform: scale(1); }
  }

  .demo-target.anim-fade { animation: demo-fade-out-in 1s ease forwards; }
  .demo-target.anim-slide { animation: demo-slide-out-in 1s ease forwards; }
  .demo-target.anim-initial { animation: demo-initial-in 0.6s ease forwards; }
</style>

<script is:inline data-astro-rerun>
(function() {
  document.querySelectorAll('.demo-play-btn:not([disabled])').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var wrap = btn.closest('.demo-wrap');
      var type = wrap.dataset.transition;
      var target = wrap.querySelector('.demo-target');
      if (!target) return;

      target.classList.remove('anim-fade', 'anim-slide', 'anim-initial');
      void target.offsetWidth;
      target.classList.add('anim-' + type);

      btn.innerHTML = '<i class="ph-bold ph-circle-notch mr-1" style="font-size:0.7rem;"></i> Playing...';
      btn.disabled = true;

      var duration = type === 'initial' ? 600 : 1000;
      setTimeout(function() {
        target.classList.remove('anim-fade', 'anim-slide', 'anim-initial');
        btn.innerHTML = '<i class="ph-bold ph-arrow-counter-clockwise mr-1" style="font-size:0.7rem;"></i> Replay';
        btn.disabled = false;
      }, duration);
    });
  });
})();
</script>
