---
/**
 * Homepage — the main landing page for Absurd Industries.
 * Shows hero, portal grid, featured campaigns, and Friends of Absurd.
 */

import BaseLayout from "../layouts/BaseLayout.astro";
import Card from "../components/Card.astro";
import Tag from "../components/Tag.astro";
import ProgressBar from "../components/ProgressBar.astro";
import { campaigns } from "../data/campaigns";
import { friends } from "../data/friends";

const featuredCampaigns = campaigns.filter((c) => c.status === "live").slice(0, 3);
---

<BaseLayout title="Open Source STEAM for Makers, Tinkerers & Rebels">
  <!-- Hero -->
  <section class="pt-20 pb-14 md:pt-24 md:pb-20">
    <div class="max-w-5xl mx-auto px-5 sm:px-6">
      <Card variant="hero">
        <div class="px-6 py-10 md:px-14 md:py-16">
          <Tag variant="stamp" class="mb-5">Open Source STEAM</Tag>

          <h1 class="font-serif text-4xl sm:text-5xl md:text-7xl font-black leading-[0.95] tracking-tight mb-5">
            Open Source,<br />Built Together
          </h1>

          <p class="text-base sm:text-lg text-ink-faint max-w-lg mb-8 leading-relaxed">
            Science, technology, engineering, art, and math — all open source. Back indie campaigns,
            request what doesn't exist, and build with a community that ships.
          </p>

          <div class="flex flex-wrap gap-3 mb-10">
            <a href="/campaigns" class="btn btn-primary">Explore Campaigns</a>
            <a href="/requests" class="btn btn-outline">Make a Request</a>
          </div>

          <!-- Stats -->
          <div class="flex flex-wrap gap-8">
            <div>
              <span class="font-serif text-2xl sm:text-3xl font-bold block">24</span>
              <span class="text-xs text-ink-faint uppercase tracking-wider">Active Campaigns</span>
            </div>
            <div>
              <span class="font-serif text-2xl sm:text-3xl font-bold block">312</span>
              <span class="text-xs text-ink-faint uppercase tracking-wider">Makers</span>
            </div>
            <div>
              <span class="font-serif text-2xl sm:text-3xl font-bold block">₹18.4L</span>
              <span class="text-xs text-ink-faint uppercase tracking-wider">Funded</span>
            </div>
          </div>
        </div>
      </Card>
    </div>
  </section>

  <!-- Portal Grid -->
  <section class="pb-14">
    <div class="max-w-5xl mx-auto px-5 sm:px-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 card-grid">
        {[
          { title: "Campaigns", desc: "Back open source projects", icon: "ph-bold ph-rocket-launch", href: "/campaigns", color: "#FF5900" },
          { title: "Makers", desc: "Discover the builders", icon: "ph-bold ph-users-three", href: "/makers", color: "#2A5F41" },
          { title: "Requests", desc: "Ask for what you need", icon: "ph-bold ph-megaphone", href: "/requests", color: "#6B5B4A" },
          { title: "Events", desc: "Bengaluru maker meetups", icon: "ph-bold ph-calendar-dots", href: "/events", color: "#CC4700" },
        ].map((item) => (
          <a href={item.href} class="card card-hover block no-underline text-ink">
            <div class="card-bg"></div>
            <div class="card-content p-5">
              <i class={item.icon} style={`color: ${item.color}; font-size: 1.75rem;`}></i>
              <h3 class="font-serif font-bold text-lg mt-3 mb-1">{item.title}</h3>
              <p class="text-xs text-ink-faint">{item.desc}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Featured Campaigns -->
  <section class="pb-14">
    <div class="max-w-5xl mx-auto px-5 sm:px-6">
      <div class="flex items-center justify-between mb-6">
        <h2 class="font-serif text-2xl sm:text-3xl font-bold">Featured Campaigns</h2>
        <a href="/campaigns" class="btn btn-ghost btn-sm">
          View all <i class="ph-bold ph-arrow-right ml-1"></i>
        </a>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 card-grid">
        {featuredCampaigns.map((campaign) => (
          <a href={`/campaigns/${campaign.slug}`} class="card card-hover block no-underline text-ink">
            <div class="card-bg"></div>
            <div class="card-content p-5">
              <div class="flex items-center gap-3 mb-4">
                <div
                  class="w-10 h-10 rounded-full flex items-center justify-center"
                  style={`background: ${campaign.avatarColor}20;`}
                >
                  <i class={campaign.icon} style={`color: ${campaign.avatarColor}; font-size: 1.1rem;`}></i>
                </div>
                <div class="flex-1 min-w-0">
                  <h3 class="font-serif font-bold text-base truncate">{campaign.title}</h3>
                  <p class="text-xs text-ink-faint">{campaign.makerName} &middot; {campaign.location}</p>
                </div>
              </div>

              <p class="text-sm text-ink-faint mb-4 line-clamp-2">{campaign.tagline}</p>

              <ProgressBar percent={campaign.percent} hot={campaign.percent >= 100} />

              <div class="flex items-center justify-between mt-3 text-xs">
                <span class="font-semibold text-funded">{campaign.percent}% funded</span>
                <span class="text-ink-faint">{campaign.backers} backers</span>
              </div>

              <div class="flex items-center gap-2 mt-3">
                <Tag variant="muted">{campaign.license}</Tag>
                {campaign.bornFromRequest && (
                  <Tag variant="stamp">Born from request</Tag>
                )}
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Friends of Absurd -->
  <section class="pb-14">
    <div class="max-w-5xl mx-auto px-5 sm:px-6">
      <Card>
        <div class="p-6 md:p-10 text-center">
          <h2 class="font-serif text-2xl font-bold mb-2">Friends of Absurd</h2>
          <p class="text-sm text-ink-faint mb-8 max-w-md mx-auto">
            The makers, communities, and companies building the open source STEAM ecosystem with us.
          </p>
          <div class="flex flex-wrap justify-center gap-8 md:gap-12">
            {friends.map((friend) => (
              <a
                href={friend.url}
                target="_blank"
                rel="noopener"
                class="friend-logo"
                title={friend.name}
              >
                <img
                  src={`/images/partners/${friend.logo}`}
                  alt={friend.name}
                  class="h-8 sm:h-10 object-contain opacity-70 hover:opacity-100 transition-opacity"
                />
                <span class="text-xs font-medium">{friend.name}</span>
              </a>
            ))}
          </div>
        </div>
      </Card>
    </div>
  </section>
</BaseLayout>
