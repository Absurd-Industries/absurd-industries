---
/**
 * Base layout for all platform pages.
 * Includes: head (fonts, icons, meta), SVG filters, wonky logo, footer, bottom bar.
 * Every page wraps its content in this layout and only needs to provide the unique body.
 */

import { ClientRouter } from "astro:transitions";
import SvgFilters from "../components/SvgFilters.astro";
import Footer from "../components/Footer.astro";
import BottomBar from "../components/BottomBar.vue";
import DesktopNav from "../components/DesktopNav.vue";
import ComingSoon from "../components/ComingSoon.vue";
import DebugPanel from "../components/DebugPanel.vue";
import "../styles/global.css";

const isDev = import.meta.env.DEV;

interface Props {
  /** Page title — appended with "| Ooru" */
  title: string;
  /** Meta description for SEO */
  description?: string;
  /** OG image URL */
  ogImage?: string;
  /** Which bottom bar tab is active: "campaigns", "makers", "requests", "events" */
  activeTab?: string;
  /** Enable dark mode (class="dark" on html) — used by inventory */
  darkMode?: boolean;
  /** Hide bottom/desktop nav — used on immersive pages like campaign detail */
  hideNav?: boolean;
}

const {
  title,
  description = "The open-source STEAM platform. Back indie campaigns, discover makers, request what you need, and build together.",
  ogImage = "/images/ooru-logo.svg",
  activeTab,
  darkMode = false,
  hideNav = false,
} = Astro.props;

const fullTitle = `${title} | Ooru`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en" class:list={[{ dark: darkMode }]}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content={darkMode ? "light dark" : "light"} />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Favicon -->
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon/favicon-16x16.png" />
    <link rel="shortcut icon" href="/favicon/favicon.ico" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&family=Fraunces:ital,opsz,wght@0,9..144,300..900;1,9..144,300..900&display=swap"
      rel="stylesheet"
    />

    <!-- Icons: Phosphor (CSS only — bold + duotone weights used) -->
    <link rel="stylesheet" href="https://unpkg.com/@phosphor-icons/web@2.1.1/src/bold/style.css" />
    <link rel="stylesheet" href="https://unpkg.com/@phosphor-icons/web@2.1.1/src/duotone/style.css" />

    <!-- Icons: FontAwesome brands (CSS webfont — no JS, survives view transitions) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/brands.min.css" integrity="sha512-8RxmFOVaKQe/xtg6lbscU9DU0IRhURWEuiI0tXevv+lXbAHfkpamD4VKFQRto9WgfOJDwOZ74c/s9Yesv3VvIQ==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/fontawesome.min.css" integrity="sha512-d0olNN35C6VLiulAobxYHZiXJmq+vl+BGIgAxQtD5+kqudro/xNMvv2yIHAciGHpExTmF6XHQZFpKBtLW5csw==" crossorigin="anonymous" referrerpolicy="no-referrer" />

    <ClientRouter />
  </head>

  <body class="font-sans text-ink min-h-screen antialiased">
    <SvgFilters />
    <ComingSoon client:load />

    <slot />

    {!hideNav && <Footer />}
    {!hideNav && <BottomBar activeTab={activeTab} client:load />}
    {!hideNav && <DesktopNav activeTab={activeTab} client:load />}
    {isDev && (
      <DebugPanel
        route={Astro.url.pathname}
        renderMode="static"
        pageTitle={title}
        client:idle
      />
    )}
  </body>
</html>
