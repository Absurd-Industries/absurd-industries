---
/**
 * Campaign card — static Astro component for the listing grid.
 *
 * Displays: icon, title, maker, tagline, progress bar, backers,
 * days left, license badge, optional community-request callout,
 * and status tag. The entire card is an anchor linking to the
 * campaign detail page.
 *
 * Usage:
 *   <CampaignCard campaign={campaign} />
 */

import Tag from "./Tag.astro";
import ProgressBar from "./ProgressBar.astro";
import type { Campaign } from "../types";

interface Props {
  campaign: Campaign;
}

const { campaign } = Astro.props;

const statusLabel =
  campaign.status === "live"
    ? "Live"
    : campaign.status === "funded"
      ? "Funded"
      : "Coming Soon";

const statusVariant =
  campaign.status === "live"
    ? "stamp"
    : campaign.status === "funded"
      ? "funded"
      : "default";

const isHot = campaign.percent >= 90 && campaign.status === "live";
---

<a
  href={`/campaigns/${campaign.slug}`}
  class="card card-hover block no-underline text-ink group"
>
  <div class="card-bg"></div>
  <div class="card-content">
    <!-- Image / icon area -->
    {campaign.image ? (
      <div class="m-4 mb-0 rounded-xl overflow-hidden" style="height: 170px;">
        <img
          src={campaign.image}
          alt={campaign.title}
          class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
          loading="lazy"
        />
      </div>
    ) : (
      <div
        class="bg-kraft-light rounded-xl flex items-center justify-center m-4 mb-0"
        style="min-height: 170px;"
      >
        <i
          class:list={[campaign.icon, "text-5xl text-kraft-dark transition-transform duration-300 group-hover:scale-110 group-hover:text-stamp"]}
        ></i>
      </div>
    )}

    <!-- Content -->
    <div class="p-5 pt-4">
      <!-- Tags row -->
      <div class="flex flex-wrap gap-2 mb-3">
        <Tag variant={statusVariant}>{statusLabel}</Tag>
        <Tag>{campaign.category}</Tag>
        <Tag>
          <i class="ph-bold ph-scales mr-1" style="font-size: 0.65rem;"></i>
          {campaign.license}
        </Tag>
      </div>

      <!-- Title -->
      <h3
        class="font-serif font-semibold text-lg text-ink mb-2 leading-snug group-hover:text-stamp transition-colors"
      >
        {campaign.title}
      </h3>

      <!-- Tagline -->
      <p class="text-ink-light text-sm leading-relaxed mb-3 line-clamp-2">
        {campaign.tagline}
      </p>

      <!-- Born from community request callout -->
      {campaign.bornFromRequest && (
        <div class="flex items-center gap-1.5 mb-3 text-xs font-semibold text-funded">
          <i class="ph-bold ph-arrow-bend-up-left"></i>
          Born from community request
        </div>
      )}

      <!-- Maker info -->
      <div class="flex items-center gap-2 mb-4">
        <div
          class="w-6 h-6 rounded-full flex items-center justify-center text-xs font-bold text-paper"
          style={`background: ${campaign.avatarColor}`}
        >
          {campaign.makerName.charAt(0)}
        </div>
        <span class="text-sm font-medium text-ink">{campaign.makerName}</span>
        <span class="text-xs text-ink-faint">&middot; {campaign.location}</span>
      </div>

      <!-- Progress bar -->
      <div class="mb-3">
        <ProgressBar percent={campaign.percent} hot={isHot} />
      </div>

      <!-- Stats row -->
      <div class="flex items-center justify-between text-sm">
        <span
          class:list={["font-semibold", campaign.percent >= 100 ? "text-funded" : "text-ink"]}
        >
          {campaign.percent}% funded
        </span>
        <span class="text-ink-faint">
          {campaign.backers} backer{campaign.backers !== 1 ? "s" : ""}
        </span>
      </div>
    </div>
  </div>
</a>
