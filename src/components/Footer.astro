---
/**
 * Site-wide footer with platform links, community links, resources, and legal.
 * Static component — no JS shipped.
 */
---

<footer class="py-10" style="background: rgba(184,149,106,0.45);">
  <div class="max-w-5xl mx-auto px-5 sm:px-6">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-8">
      <div>
        <h4 class="text-xs font-semibold uppercase tracking-wider text-ink-faint mb-3">Platform</h4>
        <ul class="space-y-2 text-sm list-none p-0 m-0">
          <li><a href="/campaigns" class="footer-link"><i class="ph-bold ph-rocket-launch"></i> Campaigns</a></li>
          <li><a href="/makers" class="footer-link"><i class="ph-bold ph-users-three"></i> Makers</a></li>
          <li><a href="/requests" class="footer-link"><i class="ph-bold ph-megaphone"></i> Requests</a></li>
          <li><a href="/events" class="footer-link"><i class="ph-bold ph-calendar-dots"></i> Events</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-xs font-semibold uppercase tracking-wider text-ink-faint mb-3">Community</h4>
        <ul class="space-y-2 text-sm list-none p-0 m-0">
          <li><a href="https://discord.gg/DUSUtguG2H" target="_blank" rel="noopener" class="footer-link"><i class="fa-brands fa-discord"></i> Discord</a></li>
          <li><a href="https://www.instagram.com/absurd.industries" target="_blank" rel="noopener" class="footer-link"><i class="fa-brands fa-instagram"></i> Instagram</a></li>
          <li><a href="https://www.youtube.com/@absurd.industries" target="_blank" rel="noopener" class="footer-link"><i class="fa-brands fa-youtube"></i> YouTube</a></li>
          <li><a href="https://www.linkedin.com/company/absurd-industries" target="_blank" rel="noopener" class="footer-link"><i class="fa-brands fa-linkedin"></i> LinkedIn</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-xs font-semibold uppercase tracking-wider text-ink-faint mb-3">Resources</h4>
        <ul class="space-y-2 text-sm list-none p-0 m-0">
          <li><a href="/hardware-devroom" class="footer-link"><i class="ph-bold ph-microchip"></i> Hardware Devroom</a></li>
          <li><a href="/contact" class="footer-link"><i class="ph-bold ph-envelope"></i> Contact</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-xs font-semibold uppercase tracking-wider text-ink-faint mb-3">Legal</h4>
        <ul class="space-y-2 text-sm list-none p-0 m-0">
          <li><a href="/privacy-policy" class="footer-link"><i class="ph-bold ph-shield-check"></i> Privacy</a></li>
          <li><a href="/terms-and-conditions" class="footer-link"><i class="ph-bold ph-file-text"></i> Terms</a></li>
          <li><a href="/policies" class="footer-link"><i class="ph-bold ph-scroll"></i> Policies</a></li>
        </ul>
      </div>
    </div>
    <div class="border-t border-ink/10 pt-5 flex flex-col sm:flex-row justify-between items-center gap-2">
      <a href="/" class="flex items-center gap-2 no-underline text-ink hover:text-stamp transition-colors">
        <img src="/images/absurd-logo.png" alt="Absurd Industries" class="h-6 w-auto" />
        <span class="text-xs font-semibold">Absurd Industries</span>
      </a>
      <p class="text-xs text-ink-faint">
        <span class="copyleft">&copy;</span> Copyleft 2023&ndash;2026. Made with curiosity in Bengaluru.
      </p>
    </div>
  </div>
</footer>

<style>
  .footer-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #1A1A1A;
    text-decoration: none;
    font-weight: 500;
    transition: color 0.15s;
  }
  .footer-link:hover {
    color: #FF5900;
    text-decoration: underline;
  }
  .footer-link i {
    font-size: 0.85rem;
    width: 1rem;
    text-align: center;
    flex-shrink: 0;
    opacity: 0.6;
  }
  .footer-link:hover i {
    opacity: 1;
  }
</style>
